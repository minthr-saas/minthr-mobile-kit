{
  "name": "@minthr-saas/mobile-ui-kit",
  "version": "0.1.0",
  "description": "MintHR mobile UI kit — React Native + Expo. Sister of the web @minthr-saas/ui-kit.",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/src/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "react-native": "./src/index.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "README.md",
    "CLAUDE.md",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "prepublishOnly": "npm run clean && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "expo",
    "ui-kit",
    "minthr",
    "components",
    "design-system"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minthr-saas/mintkit.git",
    "directory": "packages/ui-kit"
  },
  "license": "UNLICENSED",
  "publishConfig": {
    "access": "restricted"
  },
  "peerDependencies": {
    "@expo/vector-icons": "*",
    "@gorhom/bottom-sheet": ">=5",
    "@react-native-community/datetimepicker": "*",
    "@react-navigation/native": ">=7",
    "expo-document-picker": "*",
    "react": ">=18",
    "react-native": ">=0.74",
    "react-native-gesture-handler": ">=2",
    "react-native-keyboard-aware-scroll-view": ">=0.9",
    "react-native-reanimated": ">=3",
    "react-native-safe-area-context": ">=4"
  },
  "peerDependenciesMeta": {
    "@expo/vector-icons": { "optional": false },
    "@gorhom/bottom-sheet": { "optional": false },
    "@react-native-community/datetimepicker": { "optional": false },
    "@react-navigation/native": { "optional": false },
    "expo-document-picker": { "optional": false }
  },
  "devDependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@types/react": "~19.1.0",
    "del-cli": "^6.0.0",
    "expo-document-picker": "~14.0.8",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-builder-bob": "^0.35.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "typescript": "~5.9.2"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      ["typescript", { "project": "tsconfig.build.json" }]
    ]
  }
}
