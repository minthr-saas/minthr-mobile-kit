{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@minthr-saas/mobile-ui-kit": ["../../packages/ui-kit/src"],
      "@minthr-saas/mobile-ui-kit/*": ["../../packages/ui-kit/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
