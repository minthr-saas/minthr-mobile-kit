{
  "name": "mintkit-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "showcase": "npm run start --workspace=showcase",
    "build:ui-kit": "npm run build --workspace=@minthr-saas/mobile-ui-kit",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  }
}
